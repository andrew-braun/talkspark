{
	"name": "talkspark-app",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"lint:style": "stylelint \"src/styles/**/*.{css,scss}\"",
		"lint:style:fix": "stylelint \"src/**/*.{css,scss,svelte}\" --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@poppanator/sveltekit-svg": "^7.0.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.6.2",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"postcss-html": "^1.8.1",
		"postcss-scss": "^4.0.9",
		"prettier": "^3.9.3",
		"prettier-plugin-svelte": "^4.1.1",
		"sass": "^1.99.0",
		"stylelint": "^17.14.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-recommended-scss": "^17.0.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.0.11"
	},
	"type": "module",
	"volta": {
		"node": "24.15.0",
		"pnpm": "11.9.0"
	},
	"dependencies": {
		"@lottiefiles/lottie-player": "^2.0.12",
		"@popperjs/core": "^2.11.8",
		"openai": "^6.37.0",
		"valibot": "^1.4.0"
	}
}
