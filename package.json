{
	"name": "talkspark-app",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"lint:style": "stylelint \"src/**/*.{css,scss,svelte}\"",
		"lint:style:fix": "stylelint \"src/**/*.{css,scss,svelte}\" --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"knip": "svelte-kit sync && knip",
		"validate": "pnpm check && pnpm lint && pnpm lint:style && pnpm format:check && pnpm knip && pnpm test",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": "eslint --fix",
		"*.{css,scss,svelte}": "stylelint --fix",
		"*.{js,ts,svelte,css,scss,json,md,html,yml,yaml}": "prettier --write"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.1.0",
		"@commitlint/config-conventional": "^21.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@poppanator/sveltekit-svg": "^7.0.0",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"@types/node": "^25.6.2",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"knip": "^6.23.0",
		"lint-staged": "^17.0.8",
		"postcss-html": "^1.8.1",
		"postcss-scss": "^4.0.9",
		"prettier": "^3.9.3",
		"prettier-plugin-svelte": "^4.1.1",
		"sass": "^1.99.0",
		"stylelint": "^17.14.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.0.11",
		"vitest": "^4.1.9"
	},
	"type": "module",
	"volta": {
		"node": "24.15.0",
		"pnpm": "11.9.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.107.0",
		"@zag-js/dialog": "^1.42.0",
		"@zag-js/popover": "^1.42.0",
		"@zag-js/svelte": "^1.42.0",
		"openai": "^6.37.0",
		"valibot": "^1.4.0"
	}
}
